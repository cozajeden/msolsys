# MSS contact form — SMTP config
# Copy to .env and fill in. Never commit .env to git.

SMTP_HOST=mail.msolsys.com
SMTP_PORT=587
SMTP_USER=noreply@msolsys.com
SMTP_PASSWORD=change-me
SMTP_STARTTLS=true
SMTP_FROM_NAME=MSS Formularz kontaktowy
SMTP_FROM_EMAIL=noreply@msolsys.com

# Comma-separated list of recipients — team members who get the contact form
CONTACT_RECIPIENTS=arkadiusz@msolsys.com,radoslaw@msolsys.com,kontakt@msolsys.com

# Optional — send confirmation to the person who submitted the form
SEND_CONFIRMATION=true

# CORS — comma separated origins (your production + local dev)
CORS_ORIGINS=https://msolsys.com,https://www.msolsys.com,http://localhost:5173

# Rate limit (submissions per IP per hour)
RATE_LIMIT=5/hour
